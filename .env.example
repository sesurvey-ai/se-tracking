# se-tracking config — copy to .env and fill in for your environment

PORT=5400
LOG_LEVEL=INFO

# Optional API key gate for /api/* — leave empty to disable
TRACKING_API_KEY=

# Source: se-key (prod via Dokploy)
SE_KEY_URL=https://key.sesurvey.cloud
SE_KEY_API_KEY=

# Source: se-billing (prod via Dokploy)
SE_BILLING_URL=https://billing.sesurvey.cloud
SE_BILLING_TOKEN=

# Source: emcs-api (pw records)
EMCS_API_URL=http://localhost:5500       # หรือ https://emcs.sesurvey.cloud
EMCS_API_KEY=

# Source: debt-api (ตัดหนี้)
DEBT_API_URL=http://localhost:5600       # หรือ https://debt.sesurvey.cloud
DEBT_API_KEY=

# iSurvey API (cloud.isurvey.mobi) — pulls "จบงาน" report directly
ISURVEY_API_USERNAME=
ISURVEY_API_PASSWORD=
ISURVEY_INITIAL_FROM=2023-01-01
ISURVEY_API_INTERVAL_MIN=60

# Default sync interval for adapters that don't override
SYNC_INTERVAL_MIN=5

# Local SQLite cache (in Docker: /data/tracking.db)
TRACKING_DB_PATH=data/tracking.db
